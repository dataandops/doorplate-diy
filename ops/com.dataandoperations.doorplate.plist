<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent for keeping the doorplate-diy server running.

  Install:
    1. Edit the absolute paths below to match where you cloned the repo.
    2. Copy this file to ~/Library/LaunchAgents/com.dataandoperations.doorplate.plist
    3. launchctl load ~/Library/LaunchAgents/com.dataandoperations.doorplate.plist
    4. Tail logs: tail -f ~/Library/Logs/doorplate.log

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.dataandoperations.doorplate.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dataandoperations.doorplate</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/ABSOLUTE/PATH/TO/doorplate-diy/server/server.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/doorplate-diy</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/YOU/Library/Logs/doorplate.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/YOU/Library/Logs/doorplate.log</string>

    <!-- Uncomment and set a shared secret to require X-Doorplate-Token on POST /update.
    <key>EnvironmentVariables</key>
    <dict>
        <key>DOORPLATE_TOKEN</key>
        <string>change-me-to-something-random</string>
    </dict>
    -->
</dict>
</plist>
